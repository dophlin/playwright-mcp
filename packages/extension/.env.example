# Copy to `.env.local` to override (`.env*` is gitignored).
# The API base is for JSON/REST; the dashboard base is the Next app where `/connect` lives.
# `openmate_api_base_v1` / `openmate_dashboard_url` in chrome.storage.local can override at runtime.

VITE_OPENMATE_API_BASE=https://be-16-58-144-221.nip.io
VITE_OPENMATE_DASHBOARD=https://dash-16-58-144-221.nip.io
# Origins allowed to hand off sessions to the extension (include deployed dashboard + local dev if needed).
VITE_OPENMATE_DASHBOARD_ORIGINS=https://dash-16-58-144-221.nip.io,http://localhost:3001,http://127.0.0.1:3001,http://localhost:5173,http://127.0.0.1:5173
