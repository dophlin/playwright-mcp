{
  "manifest_version": 3,
  "name": "OpenMate Extension",
  "version": "0.1.0",
  "description": "Connect your Chrome browser to OpenMate so AI agents can drive the pages you are already signed in to — no separate profile, no extra login.",
  "permissions": [
    "debugger",
    "activeTab",
    "tabs",
    "tabGroups",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "lib/background.mjs",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/content/recorderContent.mjs"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["lib/content/hudContent.mjs"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["lib/content/dashboardHandoff.mjs"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/content/*.mjs", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_title": "OpenMate Extension",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
