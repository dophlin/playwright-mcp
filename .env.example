# OpenMate MCP server — environment template (M1-B)
#
# Copy to `.env` and fill in secrets. `.env` MUST be gitignored. Never commit
# a real key to the repository.
#
# Generate a key that satisfies the Q3 format (sk-om- + 48 chars [0-9A-Za-z])
# with, e.g.:
#   node -e "process.stdout.write('sk-om-' + require('crypto').randomBytes(48).toString('base64').replace(/[^0-9A-Za-z]/g,'').slice(0,48) + '\n')"

# Required. Shape: sk-om-<48 chars from [0-9A-Za-z]> (56 chars total).
OPENMATE_API_KEY=

# Port exposed on the host and inside the container.
OPENMATE_PORT=3100

# Runtime mode for Node.
NODE_ENV=production

# Optional. When set before `docker compose build`, baked into the image as
# `GIT_COMMIT_SHA` and label `org.opencontainers.image.revision` (006 T009).
# Example: export GIT_COMMIT_SHA=$(git rev-parse HEAD)
# GIT_COMMIT_SHA=
